<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <title>Calcolatrice</title>
  <style>
    body { font-family: Arial; padding: 20px; }
    input, select, button { margin: 5px; }
    #risultato { margin-top: 15px; font-weight: bold; }
  </style>
</head>
<body>

  <h2>Calcolatrice</h2>

  <form id="calcForm">
    <input type="text" id="num1" placeholder="Primo numero">
    
    <select id="operazione">
      <option value="+">+</option>
      <option value="-">-</option>
      <option value="*">*</option>
      <option value="/">/</option>
    </select>
    
    <input type="text" id="num2" placeholder="Secondo numero">
    
    <button type="submit">Calcola</button>
  </form>

  <div id="risultato"></div>

  <script>
    const form = document.getElementById("calcForm");
    const risultatoDiv = document.getElementById("risultato");

    form.addEventListener("submit", function(event) {
      event.preventDefault();

      const num1 = parseFloat(document.getElementById("num1").value);
      const num2 = parseFloat(document.getElementById("num2").value);
      const operazione = document.getElementById("operazione").value;

      // Validazione input
      if (isNaN(num1) || isNaN(num2)) {
        risultatoDiv.textContent = "Errore: inserisci numeri validi.";
        return;
      }

      let risultato;

      switch (operazione) {
        case "+":
          risultato = num1 + num2;
          break;
        case "-":
          risultato = num1 - num2;
          break;
        case "*":
          risultato = num1 * num2;
          break;
        case "/":
          if (num2 === 0) {
            risultatoDiv.textContent = "Errore: divisione per zero.";
            return;
          }
          risultato = num1 / num2;
          break;
        default:
          risultatoDiv.textContent = "Operazione non valida.";
          return;
      }

      risultatoDiv.textContent = "Risultato: " + risultato;
    });
  </script>

</body>
</html>
